# ===== Azure OpenAI (Foundry — all models via OpenAI-compatible API) =====
# Supports: GPT, Claude, DeepSeek, Grok, Kimi via Azure AI Foundry
AZURE_OPENAI_API_KEY=PLACEHOLDER
AZURE_OPENAI_ENDPOINT=https://RESOURCE.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# ===== Azure AI Foundry =====
AZURE_FOUNDRY_ENDPOINT=https://PROJECT.services.ai.azure.com/api/projects/PROJECT_NAME
AZURE_FOUNDRY_API_KEY=PLACEHOLDER
AZURE_FOUNDRY_DEPLOYMENT_NAME=deepseek-r1
AZURE_FOUNDRY_PROJECT_ID=
AZURE_FOUNDRY_REGION=eastus2

# ===== Google / Gemini =====
GOOGLE_API_KEY=AIza-PLACEHOLDER
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ===== OpenAI (optional — direct API, or leave empty if using Azure) =====
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o

# ===== Anthropic (optional — direct API, or leave empty if using Azure) =====
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# ===== Storage =====
DUCKDB_PATH=data/results/experiments.duckdb
RESULTS_DIR=data/results
TRIAGE_DIR=triage

# ===== Tracing =====
LOG_LEVEL=INFO
LOG_FORMAT=json
TRACE_ENABLED=true

# ===== Eval =====
EVAL_CONCURRENCY=5
EVAL_TIMEOUT_SECONDS=30
EVAL_TEMPERATURE=0.0
EVAL_MAX_TOKENS=1024

# ===== Canary =====
CANARY_TOKEN_SECRET=CANARY-zeph-2026-XXXXXX
